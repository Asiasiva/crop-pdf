        function setupDraggability(element, mode, layer) {
            const onDown = (e) => {
                if (currentMode !== mode) return;
                if (mode === 'canvas' && activeLayer !== layer) {
                    selectLayer(layer);
                }
                
                isDragging = true;
                dragTarget = element;
                
                const clientX = e.type.startsWith('touch') ? e.touches[0].clientX : e.clientX;
                const clientY = e.type.startsWith('touch') ? e.touches[0].clientY : e.clientY;
                
                startX = clientX - coordinates[mode][layer].x;
                startY = clientY - coordinates[mode][layer].y;
                
                if (e.cancelable) e.preventDefault();
            };

            const onMove = (e) => {
                if (!isDragging || dragTarget !== element) return;
                
                const currentClientX = e.type.startsWith('touch') ? e.touches[0].clientX : e.clientX;
                const currentClientY = e.type.startsWith('touch') ? e.touches[0].clientY : e.clientY;

                let newX = currentClientX - startX;
                let newY = currentClientY - startY;

                coordinates[mode][layer].x = Math.round(newX);
                coordinates[mode][layer].y = Math.round(newY);

                applyStyles(element, coordinates[mode][layer]);
                updateControlUI();
            };

            const onUp = () => {
                isDragging = false;
                dragTarget = null;
            };

            element.addEventListener('mousedown', onDown);
            window.addEventListener('mousemove', onMove);
            window.addEventListener('mouseup', onUp);

            element.addEventListener('touchstart', onDown, { passive: false });
            window.addEventListener('touchmove', onMove, { passive: false });
            window.addEventListener('touchend', onUp);
        }

        // Apply visual coordinates inline on DOM elements
        function applyStyles(element, coords) {
            element.style.left = coords.x + 'px';
            element.style.top = coords.y + 'px';
            element.style.width = coords.w + 'px';
            element.style.height = coords.h + 'px';
            if (coords.radius !== undefined) {
                element.style.borderRadius = coords.radius + 'px';
            }
        }

        // Update Slider UI controls to match the active layers' values
        function updateControlUI() {
            const currentCoords = coordinates[currentMode][activeLayer];
            
            sliderX.value = currentCoords.x;
            sliderY.value = currentCoords.y;
            sliderW.value = currentCoords.w;
            sliderH.value = currentCoords.h;
            sliderRadius.value = currentCoords.radius !== undefined ? currentCoords.radius : 0;

            valX.textContent = currentCoords.x + 'px';
            valY.textContent = currentCoords.y + 'px';
            valW.textContent = currentCoords.w + 'px';
            valH.textContent = currentCoords.h + 'px';
            valRadius.textContent = (currentCoords.radius !== undefined ? currentCoords.radius : 0) + 'px';

            const activeEl = currentMode === 'template' ? templatePhoto : (activeLayer === 'photo' ? canvasPhoto : canvasJathagam);
            applyStyles(activeEl, currentCoords);
        }

        // Direct coordinate updates through Sliders
        function updateActiveLayerCoordinate(prop, val) {
            const numericVal = parseInt(val);
            const activeCoords = coordinates[currentMode][activeLayer];
            activeCoords[prop] = numericVal;

            const activeEl = currentMode === 'template' ? templatePhoto : (activeLayer === 'photo' ? canvasPhoto : canvasJathagam);
            applyStyles(activeEl, activeCoords);
            updateControlUI();
        }

        // High Quality File 3 Generator & Downloader
        function downloadOutput(format) {
            const element = document.getElementById('output-canvas-page');
            
            // Temporary hide active-layer selection outlines before rendering
            const currentActiveLayerEl = currentMode === 'template' ? templatePhoto : (activeLayer === 'photo' ? canvasPhoto : canvasJathagam);
            currentActiveLayerEl.classList.remove('active-layer');

            showToast("உயர்தரக் கோப்பு உருவாக்கப்படுகிறது, தயவுசெய்து சில வினாடிகள் காத்திருக்கவும்...", "info");

            // Generate image from element using custom scale 3 for ultra sharpness (ideal for printing)
            html2canvas(element, {
                scale: 3,
                useCORS: true,
                allowTaint: true,
                backgroundColor: "#ffffff"
            }).then(canvas => {
                // Restore border outline
                currentActiveLayerEl.classList.add('active-layer');

                if (format === 'image') {
                    // Export as sharp JPG
                    const link = document.createElement('a');
                    const cleanName = detailsState.name.replace(/[^a-zA-Z0-9]/g, "_");
                    link.download = `${cleanName}_Combined_File3.jpg`;
                    link.href = canvas.toDataURL('image/jpeg', 0.95);
                    link.click();
                    showToast("JPEG கோப்பு வெற்றிகரமாக பதிவிறக்கப்பட்டது!", "success");
                } else if (format === 'pdf') {
                    // Export as structured A4 PDF
                    const { jsPDF } = window.jspdf;
                    const pdf = new jsPDF('p', 'mm', 'a4');
                    const imgData = canvas.toDataURL('image/jpeg', 0.95);
                    const cleanName = detailsState.name.replace(/[^a-zA-Z0-9]/g, "_");
                    
                    pdf.addImage(imgData, 'JPEG', 0, 0, 210, 297);
                    pdf.save(`${cleanName}_Combined_File3.pdf`);
                    showToast("PDF கோப்பு வெற்றிகரமாக பதிவிறக்கப்பட்டது!", "success");
                }
            }).catch(err => {
                showToast("கோப்பை உருவாக்குவதில் பிழை: " + err.message, "error");
                currentActiveLayerEl.classList.add('active-layer');
            });
        }
    </script>
</body>
</html>
