        }

        function exportAsPDF() {
            showToast("PDF தயாரிப்பு தொடங்கப்பட்டது. காத்திருக்கவும்...", "info");
            const prevScale = currentScale;
            setCanvasScale(1); 
            prepA4ForCapture(true);

            setTimeout(() => {
                html2canvas(document.getElementById('a4-sheet'), {
                    scale: 3,
                    useCORS: true,
                    logging: false,
                    backgroundColor: "#ffffff"
                }).then(canvas => {
                    prepA4ForCapture(false);
                    setCanvasScale(prevScale);

                    try {
                        const imgData = canvas.toDataURL('image/jpeg', 0.95);
                        const { jsPDF } = window.jspdf;
                        
                        const pdf = new jsPDF('p', 'pt', 'a4');
                        const imgWidth = 595.28; 
                        const imgHeight = 841.89; 
                        
                        pdf.addImage(imgData, 'JPEG', 0, 0, imgWidth, imgHeight);
                        pdf.save(`${getSanitizedFileName('_ஜாதகம்')}.pdf`);
                        showToast("பிரீமியம் ஜாதக PDF வெற்றிகரமாகத் தரவிறக்கம் செய்யப்பட்டது!");
                    } catch (e) {
                        showToast("PDF தயாரிப்பதில் சிக்கல் ஏற்பட்டது.", "error");
                        console.error(e);
                    }
                }).catch(err => {
                    prepA4ForCapture(false);
                    setCanvasScale(prevScale);
                    showToast("PDF உருவாக்கத்தில் பிழை.", "error");
                    console.error(err);
                });
            }, 300);
        }

        // LOCAL PROFILES DATABASE MANAGEMENT

        // Reset the loaded profile mode so users can save a copy with a new name
        function startNewProfile() {
            activeProfileId = null;
            document.getElementById('db-profile-name').value = "";
            document.getElementById('btn-new-profile').classList.add('hidden');
            showToast("புதிய ஜாதகப் பயன்முறைக்கு மாற்றப்பட்டது. இனி சேமிக்கும் போது புதிய பைலாக உருவாக்கப்படும்.", "info");
        }

        // Capture all DOM state fields into a clean JSON object
        function buildProfileDataObject(customName) {
            const defaultName = document.getElementById('varan-name').textContent.trim() || "புதிய ஜாதகம்";
            const profileTitle = customName || defaultName;
            
            // Reuse activeProfileId if we are editing an already saved file to trigger update/overwrite
            const profileId = activeProfileId || Date.now().toString();

            return {
                id: profileId,
                profileName: profileTitle,
                timestamp: Date.now(),
                lastSaved: new Date().toLocaleDateString('ta-IN') + " " + new Date().toLocaleTimeString('ta-IN'),
                theme: activeTheme,
                frame: {
                    x: frameX,
                    y: frameY,
                    zoom: sliderZoom.value,
                    panX: sliderPanX.value,
                    panY: sliderPanY.value,
                    fileName: fileNameSpan.textContent || ""
                },
                rasiData: rasiData,
                navamsamData: navamsamData,
                imageBase64: frameImage.src.startsWith('data:') ? frameImage.src : '',
                fields: {
                    deity: document.getElementById('editable-deity').textContent,
                    title: document.getElementById('editable-title').textContent,
                    subtitle: document.getElementById('editable-subtitle').textContent,
                    name: document.getElementById('varan-name').textContent,
                    dob: document.getElementById('varan-dob').textContent,
                    tob: document.getElementById('varan-tob').textContent,
                    pob: document.getElementById('varan-pob').textContent,
                    kulam: document.getElementById('varan-kulam').textContent,
                    nakshatram: document.getElementById('varan-nakshatram').textContent,
                    rasiLagnam: document.getElementById('varan-rasi-lagnam').textContent,
                    job: document.getElementById('varan-job').textContent,
                    income: document.getElementById('varan-income').textContent,
                    father: document.getElementById('varan-father').textContent,
                    mother: document.getElementById('varan-mother').textContent,
                    assets: document.getElementById('varan-assets').textContent,
                    siblings: document.getElementById('varan-siblings').textContent,
                    dasha: document.getElementById('varan-dasha').textContent,
                    phone: document.getElementById('varan-phone').textContent,
                    note: document.getElementById('varan-note').textContent,
                    branding: document.getElementById('varan-branding').textContent,
                    rasiCenter: document.querySelector('#rasi-grid .astro-center')?.textContent || "ராசி",
                    navamsamCenter: document.querySelector('#navamsam-grid .astro-center')?.textContent || "அம்சம்"
                }
            };
        }

        // Apply profile object into current DOM workspace
        function applyProfileDataToWorkspace(profile) {
            if (!profile || !profile.fields) {
                showToast("தவறான ஜாதக கோப்பு வடிவமைப்பு!", "error");
                return;
            }

            // Sync database active profile trackers
            activeProfileId = profile.id;
            document.getElementById('db-profile-name').value = profile.profileName;
            document.getElementById('btn-new-profile').classList.remove('hidden');

            // Restore theme
            if (profile.theme) {
                setHoroscopeTheme(profile.theme);
            }

            // Restore frame coordinates
            if (profile.frame) {
                frameX = parseInt(profile.frame.x) || 516;
                frameY = parseInt(profile.frame.y) || 154;
                sliderZoom.value = profile.frame.zoom || "100";
                sliderPanX.value = profile.frame.panX || "0";
                sliderPanY.value = profile.frame.panY || "0";
                
                if (profile.frame.fileName) {
                    fileNameSpan.textContent = profile.frame.fileName;
                }
            }

            // Restore image state
            if (profile.imageBase64) {
                frameImage.src = profile.imageBase64;
                frameImage.classList.remove('hidden');
                framePlaceholder.classList.add('hidden');
                uploadPlaceholder.classList.add('hidden');
                uploadSuccess.classList.remove('hidden');
            } else {
                frameImage.src = "";
                frameImage.classList.add('hidden');
                framePlaceholder.classList.remove('hidden');
                uploadPlaceholder.classList.remove('hidden');
                uploadSuccess.classList.add('hidden');
                fileNameSpan.textContent = "";
                imgNaturalWidth = 0;
                imgNaturalHeight = 0;
            }

            // Restore text elements safely with localized labels preserved
            document.getElementById('editable-deity').textContent = profile.fields.deity || "🕉️ ஸ்ரீ விநாயகர் துணை 🕉️";
            document.getElementById('editable-title').textContent = profile.fields.title || "ஜாதக வரன் விவரம்";
            document.getElementById('editable-subtitle').textContent = profile.fields.subtitle || "திருமணமே தெய்வீக பந்தம்";
            document.getElementById('varan-name').textContent = profile.fields.name || "";
            document.getElementById('varan-dob').textContent = profile.fields.dob || "";
            document.getElementById('varan-tob').textContent = profile.fields.tob || "";
            document.getElementById('varan-pob').textContent = profile.fields.pob || "";
            document.getElementById('varan-kulam').textContent = profile.fields.kulam || "";
            document.getElementById('varan-nakshatram').textContent = profile.fields.nakshatram || "";
            document.getElementById('varan-rasi-lagnam').textContent = profile.fields.rasiLagnam || "";
            document.getElementById('varan-job').textContent = profile.fields.job || "";
            document.getElementById('varan-income').textContent = profile.fields.income || "";
            document.getElementById('varan-father').textContent = profile.fields.father || "";
            document.getElementById('varan-mother').textContent = profile.fields.mother || "";
            document.getElementById('varan-assets').textContent = profile.fields.assets || "";
            document.getElementById('varan-siblings').textContent = profile.fields.siblings || "";
            document.getElementById('varan-dasha').textContent = profile.fields.dasha || "";
            document.getElementById('varan-phone').textContent = profile.fields.phone || "";
            document.getElementById('varan-note').textContent = profile.fields.note || "";
            document.getElementById('varan-branding').textContent = profile.fields.branding || "ரவி அச்சகம்,உடுமலை.";

            // Restore grids
            rasiData = profile.rasiData || JSON.parse(JSON.stringify(defaultRasiData));
            navamsamData = profile.navamsamData || JSON.parse(JSON.stringify(defaultNavamsamData));

            const rasiCenterLabel = profile.fields.rasiCenter || "ராசி";
            const navamsamCenterLabel = profile.fields.navamsamCenter || "அம்சம்";

            renderAstrologyGrid("rasi-grid", rasiData, rasiCenterLabel);
            renderAstrologyGrid("navamsam-grid", navamsamData, navamsamCenterLabel);

            updateLayout();
            showToast("சுயவிவரம் வெற்றிகரமாக ஏற்றப்பட்டது!");
        }

        // Save current profile to IndexedDB Store (Overwrites if already loaded)
        function saveCurrentProfile() {
            const nameInput = document.getElementById('db-profile-name');
            const customName = nameInput.value.trim();
            
            if (!customName) {
                showToast("தயவுசெய்து கோப்பு பெயரை உள்ளிடவும்!", "error");
                return;
            }

            const profile = buildProfileDataObject(customName);

            if (!localDatabase) {
                showToast("உள்ளூர் தரவுத்தளம் தயாராக இல்லை!", "error");
                return;
            }

            const transaction = localDatabase.transaction([STORE_NAME], 'readwrite');
            const store = transaction.objectStore(STORE_NAME);
            const request = store.put(profile);

            request.onsuccess = function() {
                if (activeProfileId) {
                    showToast(`"${profile.profileName}" வெற்றிகரமாகப் புதுப்பிக்கப்பட்டது (Updated)!`);
                } else {
                    showToast(`"${profile.profileName}" வெற்றிகரமாகச் சேமிக்கப்பட்டது!`);
                    // Hold current active id so consecutive saves update this exact record
                    activeProfileId = profile.id;
                    document.getElementById('btn-new-profile').classList.remove('hidden');
                }
                loadProfilesList(); // refresh list view
            };

            request.onerror = function() {
                showToast("சேமிப்பதில் சிக்கல் ஏற்பட்டது.", "error");
            };
        }

        // Fetch and render profiles list in the sidebar
        function loadProfilesList() {
            const listContainer = document.getElementById('saved-profiles-list');
            if (!localDatabase) return;

            const transaction = localDatabase.transaction([STORE_NAME], 'readonly');
            const store = transaction.objectStore(STORE_NAME);
            const request = store.getAll();

            request.onsuccess = function(e) {
                const profiles = e.target.result;
                if (!profiles || profiles.length === 0) {
                    listContainer.innerHTML = `<p class="text-slate-500 text-[11px] italic text-center py-2">சேமிக்கப்பட்ட விவரங்கள் எதுவும் இல்லை.</p>`;
                    return;
                }

                // Sort profiles by latest updated
                profiles.sort((a, b) => b.timestamp - a.timestamp);

                listContainer.innerHTML = '';
                profiles.forEach(profile => {
                    const row = document.createElement('div');
                    row.className = "flex items-center justify-between bg-slate-950 border border-slate-800 rounded-lg p-2 gap-2 hover:border-slate-700 transition";
                    
                    const details = document.createElement('div');
                    details.className = "flex-1 min-w-0";
                    details.innerHTML = `
                        <p class="font-bold text-slate-200 truncate leading-snug">${profile.profileName}</p>
                        <span class="text-[10px] text-slate-500 font-mono block">${profile.lastSaved}</span>
                    `;

                    // Control Actions Container
                    const actions = document.createElement('div');
                    actions.className = "flex items-center gap-1.5 shrink-0";

                    // Load Button
                    const loadBtn = document.createElement('button');
                    loadBtn.className = "bg-indigo-950 hover:bg-indigo-900 border border-indigo-800 text-indigo-400 p-1.5 rounded transition hover:scale-105";
                    loadBtn.innerHTML = '<i class="fa-solid fa-folder-open text-[11px]"></i>';
                    loadBtn.title = "திறக்க";
                    loadBtn.onclick = () => applyProfileDataToWorkspace(profile);

                    // Delete button with double-click confirm mechanism
                    const delBtn = document.createElement('button');
                    delBtn.className = "bg-slate-900 hover:bg-red-950/40 border border-slate-800 hover:border-red-900 text-slate-500 hover:text-red-400 p-1.5 rounded transition hover:scale-105";
                    delBtn.innerHTML = '<i class="fa-solid fa-trash-can text-[11px]"></i>';
                    delBtn.title = "நீக்க";
                    
                    // Double click confirmation state
                    let clickCount = 0;
                    delBtn.onclick = (event) => {
                        event.stopPropagation();
                        clickCount++;
                        if (clickCount === 1) {
                            delBtn.className = "bg-red-900 border-red-600 text-white p-1.5 rounded transition animate-pulse";
                            delBtn.innerHTML = '<i class="fa-solid fa-question text-[11px]"></i>';
                            delBtn.title = "உறுதி செய்க?";
                            
                            // Timeout to reset confirmation state if ignored
                            setTimeout(() => {
                                clickCount = 0;
                                delBtn.className = "bg-slate-900 border border-slate-800 text-slate-500 p-1.5 rounded transition";
                                delBtn.innerHTML = '<i class="fa-solid fa-trash-can text-[11px]"></i>';
                                delBtn.title = "நீக்க";
                            }, 3000);
                        } else if (clickCount === 2) {
                            deleteProfile(profile.id);
                        }
                    };

                    actions.appendChild(loadBtn);
                    actions.appendChild(delBtn);

                    row.appendChild(details);
                    row.appendChild(actions);
                    listContainer.appendChild(row);
                });
            };
        }

        // Delete profile from DB
        function deleteProfile(profileId) {
            if (!localDatabase) return;
            const transaction = localDatabase.transaction([STORE_NAME], 'readwrite');
            const store = transaction.objectStore(STORE_NAME);
            const request = store.delete(profileId);

            request.onsuccess = function() {
                showToast("சுயவிவரம் வெற்றிகரமாக நீக்கப்பட்டது.", "info");
                // If currently loaded file was deleted, reset trackers
                if (activeProfileId === profileId) {
                    activeProfileId = null;
                    document.getElementById('db-profile-name').value = "";
                    document.getElementById('btn-new-profile').classList.add('hidden');
                }
                loadProfilesList();
            };
        }

        // Export active workspace layout as JSON
        function exportProfileAsJSON() {
            const profile = buildProfileDataObject();
            const dataString = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(profile));
            const dlAnchorElem = document.createElement('a');
            
            dlAnchorElem.setAttribute("href", dataString);
            dlAnchorElem.setAttribute("download", `${getSanitizedFileName('_ஜாதகம்_தரவுக்_கோப்பு')}.json`);
            document.body.appendChild(dlAnchorElem);
            dlAnchorElem.click();
            dlAnchorElem.remove();
            
            showToast("ஜாதகக் கோப்பு (.json) வெற்றிகரமாக உங்கள் கணினியில் சேமிக்கப்பட்டது!");
        }

        // Import backup JSON file back to active layout
        function importProfileFromJSON(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const importedProfile = JSON.parse(e.target.result);
                    applyProfileDataToWorkspace(importedProfile);
                    
                    // Auto-save the imported backup file to client LocalDB for ease of reopen
                    if (localDatabase) {
                        const transaction = localDatabase.transaction([STORE_NAME], 'readwrite');
                        const store = transaction.objectStore(STORE_NAME);
                        importedProfile.id = Date.now().toString(); 
                        importedProfile.profileName = "இறக்குமதி: " + importedProfile.profileName;
                        store.put(importedProfile).onsuccess = () => {
                            // Track newly created import ID
                            activeProfileId = importedProfile.id;
                            document.getElementById('db-profile-name').value = importedProfile.profileName;
                            document.getElementById('btn-new-profile').classList.remove('hidden');
                            loadProfilesList();
                        };
                    }
                    
                } catch (err) {
                    showToast("தரவுக் கோப்பை வாசிப்பதில் தோல்வி! சரியான கோப்பை தேர்வு செய்யவும்.", "error");
                    console.error(err);
                }
            };
            reader.readAsText(file);
            event.target.value = "";
        }

        // Instructions Modal Handlers
        function showInstructions() {
            document.getElementById('instructions-modal').classList.remove('hidden');
        }
        
        function hideInstructions() {
            document.getElementById('instructions-modal').classList.add('hidden');
        }

        // Window Initial Load Trigger
        window.onload = function() {
            // Render default state astrology grids dynamically on load
            renderAstrologyGrid("rasi-grid", rasiData, "ராசி");
            renderAstrologyGrid("navamsam-grid", navamsamData, "அம்சம்");

            updateLayout();
            autoFit();

            // Initialize IndexedDB Engine
            initIndexedDB().then(() => {
                loadProfilesList();
            }).catch(err => {
                showToast("சேமிப்பகத்தை இயக்குவதில் தோல்வி!", "error");
                console.error(err);
            });
            
            // Add slight resize bounce prevention handler
            let resizeTimeout;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(() => {
                    autoFit();
                }, 200);
            });
        };
    </script>
