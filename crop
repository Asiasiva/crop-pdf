        function setCanvasScale(scale) {
            currentScale = scale;
            a4Wrapper.style.transform = `scale(${scale})`;
            
            const defaultHeight = 1123;
            const scaledHeight = defaultHeight * scale;
            const marginNeeded = Math.max(0, scaledHeight - defaultHeight);
            a4Wrapper.style.marginBottom = `${marginNeeded + 40}px`;
        }

        // Synchronize and update layout values with pure-pixel aspect ratio mapping
        function updateLayout() {
            const zoom = parseInt(sliderZoom.value);
            const panX = parseInt(sliderPanX.value);
            const panY = parseInt(sliderPanY.value);

            photoFrame.style.left = `${frameX}px`;
            photoFrame.style.top = `${frameY}px`;
            photoFrame.style.width = `${frameW}px`;
            photoFrame.style.height = `${frameH}px`;
            photoFrame.style.borderRadius = `${frameR}px`;

            if (imgNaturalWidth > 0 && imgNaturalHeight > 0) {
                // Precise Vector Cover Crop (Guarantees perfect html2canvas exports under any custom uploads)
                const Rf = frameW / frameH;
                const Ri = imgNaturalWidth / imgNaturalHeight;

                let Bw, Bh;
                if (Ri > Rf) {
                    // Image is wider than frame - match heights
                    Bh = frameH;
                    Bw = frameH * Ri;
                } else {
                    // Image is taller than or equal to frame - match widths
                    Bw = frameW;
                    Bh = frameW / Ri;
                }

                // Compute zoomed coordinates
                const W = Bw * (zoom / 100);
                const H = Bh * (zoom / 100);

                // Centering vectors
                const leftCenter = (frameW - W) / 2;
                const topCenter = (frameH - H) / 2;

                // Add slider panning offsets
                const finalLeft = leftCenter + panX;
                const finalTop = topCenter + panY;

                frameImage.style.width = `${W}px`;
                frameImage.style.height = `${H}px`;
                frameImage.style.left = `${finalLeft}px`;
                frameImage.style.top = `${finalTop}px`;
            } else {
                // Fallback state before image loads
                frameImage.style.width = `${zoom}%`;
                frameImage.style.height = `${zoom}%`;
                frameImage.style.left = `calc(${50 - (zoom / 2)}% + ${panX}px)`;
                frameImage.style.top = `calc(${50 - (zoom / 2)}% + ${panY}px)`;
            }

            valZoom.textContent = `${zoom}%`;
            valPanX.textContent = `${panX}px`;
            valPanY.textContent = `${panY}px`;
        }

