<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ஜாதக கோஆர்டினேட் இணைப்பான் - File 3 Creator</title>
    <!-- Tailwind CSS for Premium UI -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- html2canvas for Image Generation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <!-- jsPDF for PDF Generation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    
    <style>
        /* Custom scrollbar for control panels */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #1e293b;
        }
        ::-webkit-scrollbar-thumb {
            background: #475569;
            border-radius: 4px;
        }
        /* Selection border for active canvas layer */
        .active-layer {
            outline: 2px dashed #f59e0b;
            outline-offset: 2px;
        }
        /* Custom CSS to prevent text overflow in print styles */
        .page-a4 {
            width: 210mm;
            height: 297mm;
            min-width: 210mm;
            min-height: 297mm;
            background-color: white;
            color: #0f172a;
            position: relative;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border-radius: 4px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
    </style>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen font-sans flex flex-col">

    <!-- Header -->
    <header class="bg-slate-900 border-b border-slate-800 py-4 px-6 flex justify-between items-center shadow-lg sticky top-0 z-50">
        <div class="flex items-center space-x-3">
            <div class="bg-amber-500 p-2 rounded-lg text-slate-950">
                <i class="fa-solid fa-wand-magic-sparkles text-xl"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold tracking-wide">ஜாதக புகைப்பட இணைப்பான் <span class="text-amber-500 text-xs font-normal">v2.0 (AI Edition)</span></h1>
                <p class="text-xs text-slate-400">File 1 & 2-ன் கோஆர்டினேட்டுகளை மாற்றி File 3 உருவாக்குங்கள்</p>
            </div>
        </div>
        <div class="flex items-center space-x-4">
            <span class="text-xs bg-slate-800 px-3 py-1.5 rounded-full text-amber-400 font-semibold border border-amber-500/20">
                <i class="fa-solid fa-circle-check mr-1.5"></i> திருக்கணித முறை / AI தானியங்கி வாசிப்பு
            </span>
        </div>
    </header>

    <!-- Custom Toast Notification System -->
    <div id="toast-container" class="fixed top-20 right-6 z-50 flex flex-col gap-2 pointer-events-none"></div>

    <!-- Main Container -->
    <div class="flex-1 flex flex-col lg:flex-row overflow-hidden">
        
        <!-- Sidebar Controls -->
        <aside class="w-full lg:w-96 bg-slate-900 border-r border-slate-800 flex flex-col overflow-y-auto">
            
            <!-- Tab Buttons to Segment Editing Features -->
            <div class="grid grid-cols-4 border-b border-slate-800 bg-slate-950 text-xs">
                <button onclick="switchSidebarTab('files')" id="tab-btn-files" class="py-3 font-semibold text-center border-b-2 border-amber-500 text-amber-400">
                    <i class="fa-solid fa-folder-open block mb-1 text-sm"></i> கோப்புகள் / AI
                </button>
                <button onclick="switchSidebarTab('details')" id="tab-btn-details" class="py-3 font-semibold text-center text-slate-400 hover:text-slate-200">
                    <i class="fa-solid fa-user-edit block mb-1 text-sm"></i> விபரங்கள்
                </button>
                <button onclick="switchSidebarTab('charts')" id="tab-btn-charts" class="py-3 font-semibold text-center text-slate-400 hover:text-slate-200">
                    <i class="fa-solid fa-table-cells block mb-1 text-sm"></i> கட்டங்கள்
                </button>
                <button onclick="switchSidebarTab('coords')" id="tab-btn-coords" class="py-3 font-semibold text-center text-slate-400 hover:text-slate-200">
                    <i class="fa-solid fa-arrows-up-down-left-right block mb-1 text-sm"></i> அளவு
                </button>
            </div>

            <div class="p-6 space-y-6 flex-1">
                
                <!-- MODE SELECTOR (Always Visible) -->
                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2">வடிவமைப்பு முறை (Select Mode)</label>
                    <div class="grid grid-cols-2 gap-2 bg-slate-950 p-1 rounded-lg border border-slate-800">
                        <button id="btn-mode-template" onclick="switchMode('template')" class="py-2 text-xs font-semibold rounded bg-amber-500 text-slate-950 transition-all">
                            <i class="fa-solid fa-id-card mr-1"></i> ஜாதகப் படிவம்
                        </button>
                        <button id="btn-mode-canvas" onclick="switchMode('canvas')" class="py-2 text-xs font-semibold rounded text-slate-400 hover:text-white transition-all">
                            <i class="fa-solid fa-crop-simple mr-1"></i> நேரடி Canvas
                        </button>
                    </div>
                </div>

                <!-- TAB 1: FILES & AI EXTRACTION -->
                <div id="tab-content-files" class="space-y-5">
                    
                    <!-- AI Extraction Panel -->
                    <div class="bg-indigo-950/40 p-4 rounded-xl border border-indigo-500/30 space-y-3">
                        <div class="flex items-center justify-between">
                            <h3 class="text-xs font-bold text-indigo-300 uppercase tracking-wider">
                                <i class="fa-solid fa-robot mr-2 text-indigo-400"></i>AI மூலம் தானாக எழுத
                            </h3>
                            <span class="text-[10px] bg-indigo-500/20 text-indigo-300 px-2 py-0.5 rounded-full">Gemini AI</span>
                        </div>
                        <p class="text-[11px] text-slate-300 leading-relaxed">
                            ஜாதக விபரங்கள் உள்ள கோப்பை (File 1) அப்லோட் செய்த பின், கீழுள்ள பொத்தானை அழுத்தவும். AI அதன் எழுத்துக்களைப் படித்து அனைத்தையும் தானாகவே நிரப்பும்!
                        </p>
                        
                        <button onclick="extractHoroscopeWithAI()" id="ai-extract-btn" class="w-full py-2.5 px-3 bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white font-bold text-xs rounded-lg shadow-md transition flex items-center justify-center gap-2">
                            <i class="fa-solid fa-brain-circuit"></i> <span id="ai-btn-text">AI ஜாதக வாசிப்பைத் தொடங்கு</span>
                        </button>
                    </div>

                    <!-- Upload Panel -->
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 space-y-4">
                        <h3 class="text-sm font-bold text-amber-400"><i class="fa-solid fa-upload mr-2"></i>கோப்புகளை பதிவேற்றவும்</h3>
                        
                        <div>
                            <label class="block text-xs text-slate-400 mb-1.5 font-medium">File 1: ஜாதகம் / பின்னணிப் படம்</label>
                            <div class="relative group">
                                <input type="file" id="upload-file1" accept="image/*" onchange="handleFileUpload(event, 'file1')" class="hidden">
                                <label for="upload-file1" id="file1-label" class="flex items-center justify-center w-full py-3 px-4 bg-slate-800 hover:bg-slate-750 border border-slate-700 hover:border-amber-500 rounded-lg cursor-pointer transition text-xs font-medium text-slate-300">
                                    <i class="fa-solid fa-file-image mr-2 text-amber-500"></i> ஜாதகப் படம் அப்லோட்
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs text-slate-400 mb-1.5 font-medium">File 2: நபர் புகைப்படம் (Photo)</label>
                            <div class="relative group">
                                <input type="file" id="upload-file2" accept="image/*" onchange="handleFileUpload(event, 'file2')" class="hidden">
                                <label for="upload-file2" id="file2-label" class="flex items-center justify-center w-full py-3 px-4 bg-slate-800 hover:bg-slate-750 border border-slate-700 hover:border-amber-500 rounded-lg cursor-pointer transition text-xs font-medium text-slate-300">
                                    <i class="fa-solid fa-user-tie mr-2 text-amber-500"></i> நபர் படம் அப்லோட்
                                </label>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- TAB 2: MANUAL DETAIL EDITOR -->
                <div id="tab-content-details" class="hidden space-y-4">
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 space-y-4 text-xs">
                        <h3 class="text-sm font-bold text-amber-400 border-b border-slate-800 pb-2">
                            <i class="fa-solid fa-user-pen mr-2"></i>தலைப்பு மற்றும் பெயர் விபரங்கள்
                        </h3>
                        
                        <div class="space-y-3">
                            <div>
                                <label class="block text-slate-400 mb-1">துணை வாசகம் (எ.கா: குலதெய்வம்)</label>
                                <input type="text" id="edit-subdeity" oninput="updateFieldState('subdeity', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-slate-400 mb-1">கோத்திரம் / குலம் / ஜாதி</label>
                                <input type="text" id="edit-caste" oninput="updateFieldState('caste', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-slate-400 mb-1">பெயர் & படிப்பு</label>
                                <input type="text" id="edit-name" oninput="updateFieldState('name', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-slate-400 mb-1">பிறந்த தேதி (தமிழ் மாதம் உட்பட)</label>
                                <input type="text" id="edit-dob" oninput="updateFieldState('dob', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                            </div>
                            <div class="grid grid-cols-2 gap-2">
                                <div>
                                    <label class="block text-slate-400 mb-1">பிறந்த நேரம்</label>
                                    <input type="text" id="edit-tob" oninput="updateFieldState('tob', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                                </div>
                                <div>
                                    <label class="block text-slate-400 mb-1">பிறந்த ஊர்</label>
                                    <input type="text" id="edit-pob" oninput="updateFieldState('pob', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-2">
                                <div>
                                    <label class="block text-slate-400 mb-1">நட்சத்திரம் & ராசி</label>
                                    <input type="text" id="edit-starRasi" oninput="updateFieldState('starRasi', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                                </div>
                                <div>
                                    <label class="block text-slate-400 mb-1">லக்னம் & யோகம்</label>
                                    <input type="text" id="edit-lagnam" oninput="updateFieldState('lagnam', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 space-y-4 text-xs">
                        <h3 class="text-sm font-bold text-amber-400 border-b border-slate-800 pb-2">
                            <i class="fa-solid fa-house-chimney mr-2"></i>குடும்பம் & சொத்து விபரங்கள்
                        </h3>
                        <div class="space-y-3">
                            <div class="grid grid-cols-2 gap-2">
                                <div>
                                    <label class="block text-slate-400 mb-1">தந்தை பெயர்</label>
                                    <input type="text" id="edit-father" oninput="updateFieldState('father', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                                </div>
                                <div>
                                    <label class="block text-slate-400 mb-1">தாயார் பெயர்</label>
                                    <input type="text" id="edit-mother" oninput="updateFieldState('mother', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                                </div>
                            </div>
                            <div>
                                <label class="block text-slate-400 mb-1">உடன் பிறந்தோர்</label>
                                <input type="text" id="edit-siblings" oninput="updateFieldState('siblings', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-slate-400 mb-1">சொத்துக்கள்</label>
                                <input type="text" id="edit-assets" oninput="updateFieldState('assets', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                            </div>
                            <div class="grid grid-cols-2 gap-2">
                                <div>
                                    <label class="block text-slate-400 mb-1">வேலை / தொழில்</label>
                                    <input type="text" id="edit-job" oninput="updateFieldState('job', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                                </div>
                                <div>
                                    <label class="block text-slate-400 mb-1">மாத வருமானம்</label>
                                    <input type="text" id="edit-income" oninput="updateFieldState('income', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                                </div>
                            </div>
                            <div>
                                <label class="block text-slate-400 mb-1">திசை இருப்பு விபரம்</label>
                                <input type="text" id="edit-dasha" oninput="updateFieldState('dasha', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-slate-400 mb-1">தொடர்பு எண் (Phone)</label>
                                <input type="text" id="edit-phone" oninput="updateFieldState('phone', this.value)" class="w-full bg-slate-800 border border-slate-700 rounded px-2.5 py-1.5 text-white focus:border-amber-500 outline-none">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TAB 3: VISUAL ASTROLOGY CHART EDITOR -->
                <div id="tab-content-charts" class="hidden space-y-4">
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 text-xs space-y-4">
                        <div class="flex justify-between items-center border-b border-slate-800 pb-2">
                            <h3 class="text-sm font-bold text-amber-400"><i class="fa-solid fa-table-cells mr-2"></i>கட்டங்களில் கிரகங்களை மாற்றுக</h3>
                            <div class="flex space-x-1">
                                <button onclick="setChartFocus('rasi')" id="btn-chartfocus-rasi" class="px-2 py-1 rounded bg-amber-500 text-slate-950 font-bold text-[10px]">இராசி</button>
                                <button onclick="setChartFocus('navamsam')" id="btn-chartfocus-navamsam" class="px-2 py-1 rounded bg-slate-800 text-slate-300 font-bold text-[10px]">நவாம்சம்</button>
                            </div>
                        </div>

                        <p class="text-[10px] text-slate-400">
                            விருச்சிகம், மேஷம், ரிஷபம் போன்ற கட்டங்களுக்குரிய கிரகங்களை நேரடியாக இங்கு டைப் செய்யுங்கள்.
                        </p>

                        <!-- Dynamically Generated Inputs for the Selected Chart -->
                        <div id="zodiac-house-inputs" class="grid grid-cols-2 gap-3">
                            <!-- JS will inject 12 inputs here dynamically -->
                        </div>
                    </div>
                </div>

                <!-- TAB 4: LAYER POSITION COORDINATES -->
                <div id="tab-content-coords" class="hidden space-y-4">
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 space-y-4">
                        <div class="flex justify-between items-center">
                            <h3 class="text-sm font-bold text-amber-400"><i class="fa-solid fa-sliders mr-2"></i>கோஆர்டினேட்ஸ் திருத்தம்</h3>
                            <span id="active-layer-indicator" class="text-[10px] bg-indigo-500/20 text-indigo-400 border border-indigo-500/30 px-2 py-0.5 rounded font-mono">புகைப்படம் தேர்வு</span>
                        </div>

                        <!-- Layer Selector Buttons -->
                        <div class="grid grid-cols-2 gap-2">
                            <button onclick="selectLayer('photo')" id="select-photo-layer" class="py-1.5 text-xs font-semibold rounded bg-slate-800 text-white border border-indigo-500">
                                புகைப்படம்
                            </button>
                            <button onclick="selectLayer('jathagam')" id="select-jathagam-layer" class="py-1.5 text-xs font-semibold rounded bg-slate-900 text-slate-400 border border-transparent">
                                ஜாதகப் படம்
                            </button>
                        </div>

                        <!-- Sliders for precise coordinates -->
                        <div class="space-y-4 pt-2 text-xs">
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-slate-400 font-medium">இடம் X (Horizontal Pos)</span>
                                    <span id="val-x" class="font-mono text-amber-400">100px</span>
                                </div>
                                <input type="range" id="slider-x" min="-100" max="600" value="40" class="w-full accent-amber-500 bg-slate-800 h-1.5 rounded-lg appearance-none cursor-pointer" oninput="updateActiveLayerCoordinate('x', this.value)">
                            </div>

                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-slate-400 font-medium">இடம் Y (Vertical Pos)</span>
                                    <span id="val-y" class="font-mono text-amber-400">100px</span>
                                </div>
                                <input type="range" id="slider-y" min="-100" max="900" value="40" class="w-full accent-amber-500 bg-slate-800 h-1.5 rounded-lg appearance-none cursor-pointer" oninput="updateActiveLayerCoordinate('y', this.value)">
                            </div>

                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-slate-400 font-medium">அகலம் (Width)</span>
                                    <span id="val-w" class="font-mono text-amber-400">180px</span>
                                </div>
                                <input type="range" id="slider-w" min="50" max="800" value="180" class="w-full accent-amber-500 bg-slate-800 h-1.5 rounded-lg appearance-none cursor-pointer" oninput="updateActiveLayerCoordinate('w', this.value)">
                            </div>

                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-slate-400 font-medium">உயரம் (Height)</span>
                                    <span id="val-h" class="font-mono text-amber-400">240px</span>
                                </div>
                                <input type="range" id="slider-h" min="50" max="850" value="240" class="w-full accent-amber-500 bg-slate-800 h-1.5 rounded-lg appearance-none cursor-pointer" oninput="updateActiveLayerCoordinate('h', this.value)">
                            </div>

                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-slate-400 font-medium">வட்டவடிவம் (Border Radius)</span>
                                    <span id="val-radius" class="font-mono text-amber-400">12px</span>
                                </div>
                                <input type="range" id="slider-radius" min="0" max="100" value="12" class="w-full accent-amber-500 bg-slate-800 h-1.5 rounded-lg appearance-none cursor-pointer" oninput="updateActiveLayerCoordinate('radius', this.value)">
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Export Buttons (At Footer of Sidebar) -->
            <div class="p-6 border-t border-slate-800 bg-slate-950 space-y-2.5">
                <button onclick="downloadOutput('image')" class="w-full py-3 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-slate-950 font-bold rounded-xl shadow-lg hover:shadow-amber-500/10 active:scale-[0.98] transition duration-200">
                    <i class="fa-solid fa-file-image mr-2 text-lg"></i> File 3 - ஆக மாற்றுக (JPEG)
