        // Frame Drag and Drop Engine Logic
        function startDrag(e) {
            if (e.target !== photoFrame && !photoFrame.contains(e.target)) return;
            if (e.target.tagName === 'INPUT') return;

            isDragging = true;
            photoFrame.classList.add('active-layer');

            const clientX = e.type.startsWith('touch') ? e.touches[0].clientX : e.clientX;
            const clientY = e.type.startsWith('touch') ? e.touches[0].clientY : e.clientY;

            startX = clientX;
            startY = clientY;
            originalLeft = parseInt(photoFrame.style.left) || 0;
            originalTop = parseInt(photoFrame.style.top) || 0;

            if (e.cancelable) e.preventDefault();
        }

        // Handle Touch and Mouse movements
        function doDrag(e) {
            if (!isDragging) return;

            const clientX = e.type.startsWith('touch') ? e.touches[0].clientX : e.clientX;
            const clientY = e.type.startsWith('touch') ? e.touches[0].clientY : e.clientY;

            const deltaX = (clientX - startX) / currentScale;
            const deltaY = (clientY - startY) / currentScale;

            let targetX = Math.round(originalLeft + deltaX);
            let targetY = Math.round(originalTop + deltaY);

            targetX = Math.max(-100, Math.min(600, targetX));
            targetY = Math.max(-100, Math.min(900, targetY));

            frameX = targetX;
            frameY = targetY;

            updateLayout();
        }

        // Stop dragging action
        function stopDrag() {
            if (isDragging) {
                isDragging = false;
            }
        }

        photoFrame.addEventListener('mousedown', startDrag);
        window.addEventListener('mousemove', doDrag);
        window.addEventListener('mouseup', stopDrag);

        photoFrame.addEventListener('touchstart', startDrag, { passive: false });
        window.addEventListener('touchmove', doDrag, { passive: false });
        window.addEventListener('touchend', stopDrag);

