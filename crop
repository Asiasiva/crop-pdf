        // Workspace Scaling
        function autoFit() {
            const workspace = document.querySelector('main');
            const targetWidth = 794;
            const targetHeight = 1123;
            const padding = 32; 
            
            const availableWidth = workspace.clientWidth - padding;
            const availableHeight = workspace.clientHeight - padding - 60; 
            
            const widthScale = availableWidth / targetWidth;
            const heightScale = availableHeight / targetHeight;
            
            let finalScale = Math.min(widthScale, heightScale);
            finalScale = Math.max(0.3, Math.min(1.1, finalScale)); 
            
            setCanvasScale(finalScale);
        }

